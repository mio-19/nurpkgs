{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "allow-custom-commands",
      "allow": [
        { "name": "create_session_id" },
        { "name": "start_session" },
        { "name": "write_session" },
        { "name": "resize_session" },
        { "name": "stop_session" },
        { "name": "get_ssh_hosts" }
      ]
    }
  ]
}
